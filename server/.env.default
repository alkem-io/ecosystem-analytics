ALKEMIO_SERVER_URL=https://alkem.io
ALKEMIO_GRAPHQL_ENDPOINT=https://alkem.io/api/private/non-interactive/graphql
ALKEMIO_KRATOS_PUBLIC_URL=https://identity.alkem.io

# Optional
PUBLIC_URL=http://localhost:4000
PORT=4000
MAX_SPACES_PER_QUERY=10
CACHE_TTL_HOURS=24

# Local dev: enable Kratos API flow login (bypasses SSO redirect).
# In production, SSO redirect is used and this MUST be false/unset.
DEV_AUTH_BYPASS=true
