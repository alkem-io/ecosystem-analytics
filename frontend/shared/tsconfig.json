{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@server/types/*": ["../../server/src/types/*"]
    }
  },
  "include": ["src/**/*", "../../server/src/types/**/*"]
}
