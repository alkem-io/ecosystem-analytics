ALKEMIO_SERVER_URL=https://alkem.io
ALKEMIO_GRAPHQL_ENDPOINT=https://alkem.io/api/private/non-interactive/graphql

# Optional
ECOSYSTEM_ANALYTICS_BACKEND_PORT=4000
