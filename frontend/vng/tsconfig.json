{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@ea/shared": ["../shared/src/index.ts"],
      "@ea/shared/*": ["../shared/src/*"],
      "@server/types/*": ["../../server/src/types/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../shared/src/**/*", "../../server/src/types/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
