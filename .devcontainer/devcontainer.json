{
  "name": "Ecosystem Analytics",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // The repo is mounted here; matches WORKDIR in the Dockerfile.
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  "remoteUser": "node",

  "containerEnv": {
    "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright",
    // Let corepack auto-provision the pinned pnpm without an interactive
    // prompt (postCreate runs non-interactively).
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
  },

  // Dev servers: BFF 4100 / vng 4101 / govtech 4102, and the three Vite
  // dev servers 5173 (explorer) / 5174 (vng) / 5175 (govtech).
  "forwardPorts": [4100, 4101, 4102, 5173, 5174, 5175],
  "portsAttributes": {
    "4100": { "label": "BFF (server)", "onAutoForward": "silent" },
    "4101": { "label": "BFF vng", "onAutoForward": "silent" },
    "4102": { "label": "BFF govtech", "onAutoForward": "silent" },
    "5173": { "label": "Explorer SPA", "onAutoForward": "notify" },
    "5174": { "label": "VNG SPA", "onAutoForward": "silent" },
    "5175": { "label": "GovTech SPA", "onAutoForward": "silent" }
  },

  // Persist Claude Code auth/config and the pnpm store across rebuilds so
  // you don't re-login or re-download packages every time.
  "mounts": [
    "source=ea-claude-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=ea-pnpm-store-${devcontainerId},target=/home/node/.local/share/pnpm/store,type=volume"
  ],

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-playwright.playwright",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
