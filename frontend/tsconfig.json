{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@server/types/*": ["../server/src/types/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../server/src/types/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
