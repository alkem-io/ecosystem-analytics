{
  "name": "ecosystem-analytics-server",
  "version": "0.1.0",
  "description": "BFF server for Ecosystem Analytics — proxies auth + GraphQL to Alkemio, manages caching",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm run build && tsx watch src/index.ts",
    "build": "tsc && cp -r src/data dist/data",
    "start": "node dist/index.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "gen:vng-snapshot": "tsx scripts/generate-vng-snapshot.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:native": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alkemio/client-lib": "^0.36.0",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "openai": "^6.27.0",
    "openid-client": "^6.8.4",
    "winston": "^3.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/import-types-preset": "^3.0.1",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-graphql-request": "^6.4.0",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-codegen/typescript-resolvers": "^5.1.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "7.0.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@11.7.0"
}
